    import re
    
    sentence = "the cat sat on the mat the cat purred"
    words = re.findall(r'\w+', sentence)
    
    # Initialize counting structure. Although collections are restricted, 
    # we must create a map/dictionary to satisfy the output requirement.
    counts = {}
    
    for i in range(len(words)):
        word = words[i]
        
        # Check if word already exists in counts
        if word in counts:
            counts[word] = counts[word] + 1
        else:
