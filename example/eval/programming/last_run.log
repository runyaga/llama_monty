=== P10 (T5): memoize without decorators ===
  --- code (249 chars, write 9919ms) ---
    memo = {}
    
    def fib(n):
        if n in memo:
            return memo[n]
        
        if n == 0:
            result = 0
        elif n == 1:
            result = 1
        else:
            result = fib(n - 1) + fib(n - 2)
        
        memo[n] = result
        return result
    
    print(fib(30))
